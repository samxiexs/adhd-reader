# A single OpenAI-compatible provider. This is enough for a basic deployment.
# OPENAI_API_KEY=replace_me
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Or configure multiple OpenAI-compatible providers. The key values themselves
# remain separate environment variables and are never sent to the browser.
# AI_PROVIDERS_JSON=[{"id":"openai","label":"OpenAI","baseUrl":"https://api.openai.com/v1","model":"gpt-4.1-mini","apiKeyEnv":"OPENAI_API_KEY"},{"id":"internal","label":"Internal model","baseUrl":"https://model.example.com/v1","model":"model-name","apiKeyEnv":"INTERNAL_MODEL_API_KEY"}]
# OPENAI_API_KEY=replace_me
# INTERNAL_MODEL_API_KEY=replace_me
